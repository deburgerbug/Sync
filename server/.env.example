# Server
PORT=5000

# Database (Neon PostgreSQL)
# Pooled connection — used by Prisma Client at runtime
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct connection — used by Prisma CLI for migrations (no -pooler in hostname)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Auth
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_strong_random_secret_here"

# Client URL (for CORS) — use http://localhost:5173 for local dev
CLIENT_URL="http://localhost:5173"

# Environment
NODE_ENV="development"